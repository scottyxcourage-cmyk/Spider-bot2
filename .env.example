# ── Server ──────────────────────────────────────────────────────────────
PORT=3000
# Your full public URL (no trailing slash). Used in email links.
PUBLIC_URL=https://your-app.pxxl.run
NODE_ENV=production

# ── Auth ────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# ── Database ─────────────────────────────────────────────────────────────
# pxxl: set this to your persistent volume path e.g. /data
# Leave blank to use ./data/ (works locally, may reset on redeploy)
DATA_DIR=

# ── Gmail SMTP ──────────────────────────────────────────────────────────
# 1. Enable 2FA on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Create an App Password for "Mail"
# 4. Use that 16-char password below (NOT your normal Gmail password)
GMAIL_USER=you@gmail.com
GMAIL_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM=Spider Hub <you@gmail.com>

# ── Google Sign-In (optional) ───────────────────────────────────────────
# Create at https://console.cloud.google.com/ → APIs → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Needed for the redirect-flow fallback (works even when the Google JS SDK
# is blocked). Get it from the same OAuth 2.0 Client ID page as above.
GOOGLE_CLIENT_SECRET=your-google-client-secret
# In Google Cloud Console, also add to "Authorized redirect URIs":
#   ${PUBLIC_URL}/api/auth/google/callback
# e.g. https://spider-bot2.pxxl.run/api/auth/google/callback

# ── TMDb API (Movies) ───────────────────────────────────────────────────
# Free at https://www.themoviedb.org/settings/api
# The key is proxied through the backend — never exposed to the browser
TMDB_API_KEY=your-tmdb-api-key-here

# ── AI Chat (OpenAI) ─────────────────────────────────────────────────────
# Get a key at https://platform.openai.com/api-keys
# The key is proxied through the backend — never exposed to the browser
OPENAI_API_KEY=sk-your-openai-key-here
# Optional overrides:
OPENAI_MODEL=gpt-4o-mini
AI_DAILY_LIMIT=15
# Only needed if you switch models or OpenAI changes pricing —
# defaults already match gpt-4o-mini's list price.
OPENAI_INPUT_COST_PER_1M=0.15
OPENAI_OUTPUT_COST_PER_1M=0.60

# ── Admin Dashboard ─────────────────────────────────────────────────────
# Visit /admin.html and enter this key to access the admin panel
ADMIN_KEY=choose-a-strong-secret-password-here

# ── NOTES FOR pxxl.run ──────────────────────────────────────────────────
# - Requires Node 22.5+ (pxxl uses Node 26 ✓)
# - Set DATA_DIR to your persistent volume so the database survives redeploys
# - Set PUBLIC_URL to your actual pxxl domain for email links to work
